{
   "badges":[
      {
         "type":"origins:tooltip",
         "sprite":"origins:textures/gui/badge/toggle.png",
         "text":{
            "translate":"badge.quirks.limitless.white_toggle",
            "with":[
               {
                  "keybind":"key.quirks.senary"
               }
            ]
         }
      },
      {
         "type":"origins:tooltip",
         "sprite":"origins:textures/gui/badge/info.png",
         "text":{
            "translate":"badge.quirks.limitless.white_info"
         }
      }
   ],
   "type":"origins:multiple",
   "resource":{
      "type":"origins:resource",
      "min":0,
      "max":1,
      "hud_render":{
         "should_render":false
      },
      "start_value":0
   },
   "toggle":{
      "type":"origins:active_self",
      "entity_action":{
         "type":"origins:if_else",
         "condition":{
            "type":"origins:resource",
            "resource":"quirks:limitless/white_resource",
            "comparison":"==",
            "compare_to":0
         },
         "if_action":{
            "type":"origins:and",
            "actions":[
               {
                  "type":"origins:modify_resource",
                  "modifier":{
                     "operation":"set_total",
                     "value":1.00
                  },
                  "resource":"quirks:limitless/white_resource"
               },
               {
                  "type":"origins:play_sound",
                  "sound":"minecraft:block.beacon.activate",
                  "volume":1.00,
                  "pitch":1.50
               },
               {
                  "type":"origins:play_sound",
                  "sound":"minecraft:block.amethyst_block.chime",
                  "volume":1.00,
                  "pitch":0.80
               },
               {
                  "type":"origins:execute_command",
                  "command":"title @s actionbar {\"translate\":\"actionbar.quirks.limitless.white_active\",\"color\":\"white\",\"bold\":true,\"italic\":false,\"underlined\":false,\"strikethrough\":false,\"obfuscated\":false}"
               }
            ]
         },
         "else_action":{
            "type":"origins:and",
            "actions":[
               {
                  "type":"origins:modify_resource",
                  "modifier":{
                     "operation":"set_total",
                     "value":0.00
                  },
                  "resource":"quirks:limitless/white_resource"
               },
               {
                  "type":"origins:play_sound",
                  "sound":"minecraft:block.beacon.deactivate",
                  "volume":0.80,
                  "pitch":1.00
               }
            ]
         }
      },
      "cooldown":20,
      "hud_render":{
         "should_render":false
      },
      "key":{
         "key":"key.quirks.senary",
         "continuous":false
      },
      "condition":{
         "type":"origins:and",
         "conditions":[
            {
               "type":"origins:resource",
               "resource":"quirks:limitless/awakening_resource",
               "comparison":"==",
               "compare_to":1
            },
            {
               "type":"origins:resource",
               "resource":"quirks:limitless/stamina_spatial_energy",
               "comparison":">=",
               "compare_to":200
            },
            {
               "type":"origins:resource",
               "resource":"quirks:universal/quirk_erased",
               "comparison":"==",
               "compare_to":0
            }
         ]
      }
   },
   "enemy_debuffs":{
      "type":"origins:action_over_time",
      "entity_action":{
         "type":"origins:area_of_effect",
         "radius":8.00,
         "shape":"sphere",
         "bientity_action":{
            "type":"origins:target_action",
            "action":{
               "type":"origins:and",
               "actions":[
                  {
                     "type":"origins:apply_effect",
                     "effect":{
                        "effect":"minecraft:slowness",
                        "duration":40,
                        "amplifier":2,
                        "is_ambient":false,
                        "show_particles":true,
                        "show_icon":true
                     }
                  },
                  {
                     "type":"origins:apply_effect",
                     "effect":{
                        "effect":"minecraft:weakness",
                        "duration":40,
                        "amplifier":1,
                        "is_ambient":false,
                        "show_particles":true,
                        "show_icon":true
                     }
                  },
                  {
                     "type":"origins:apply_effect",
                     "effect":{
                        "effect":"minecraft:levitation",
                        "duration":10,
                        "amplifier":0,
                        "is_ambient":false,
                        "show_particles":false,
                        "show_icon":false
                     }
                  }
               ]
            }
         },
         "bientity_condition":{
            "type":"origins:target_condition",
            "condition":{
               "type":"origins:living"
            }
         },
         "include_target":false
      },
      "interval":20,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/white_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "self_speed":{
      "type":"origins:conditioned_attribute",
      "modifier":{
         "attribute":"minecraft:generic.movement_speed",
         "operation":"multiply_base",
         "value":0.30,
         "name":"Limitless Absolute Space Speed"
      },
      "tick_rate":20,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/white_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "self_strength":{
      "type":"origins:conditioned_attribute",
      "modifier":{
         "attribute":"minecraft:generic.attack_damage",
         "operation":"multiply_base",
         "value":0.50,
         "name":"Limitless Absolute Space Strength"
      },
      "tick_rate":20,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/white_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "self_resistance":{
      "type":"origins:modify_damage_taken",
      "modifier":{
         "operation":"multiply_total",
         "value":-0.30
      },
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/white_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "energy_drain":{
      "type":"origins:action_over_time",
      "entity_action":{
         "type":"origins:if_else",
         "condition":{
            "type":"origins:resource",
            "resource":"quirks:limitless/stamina_spatial_energy",
            "comparison":"<=",
            "compare_to":0
         },
         "if_action":{
            "type":"origins:modify_resource",
            "modifier":{
               "operation":"set_total",
               "value":0.00
            },
            "resource":"quirks:limitless/white_resource"
         },
         "else_action":{
            "type":"origins:modify_resource",
            "modifier":{
               "operation":"add_base_early",
               "value":-15.00
            },
            "resource":"quirks:limitless/stamina_spatial_energy"
         }
      },
      "interval":1,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/white_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "mental_drain":{
      "type":"origins:action_over_time",
      "entity_action":{
         "type":"origins:modify_resource",
         "modifier":{
            "operation":"add_base_early",
            "value":-1.00
         },
         "resource":"quirks:limitless/stamina_mental_strain"
      },
      "interval":10,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/white_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "active_particles":{
      "type":"origins:particle",
      "particle":"minecraft:end_rod",
      "frequency":1,
      "count":12,
      "speed":0.10,
      "spread":{
         "x":2.00,
         "y":1.50,
         "z":2.00
      },
      "offset_y":0.50,
      "visible_in_first_person":false,
      "visible_while_invisible":false,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/white_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "active_dust_particles":{
      "type":"origins:particle",
      "particle":{
         "type":"minecraft:dust",
         "params":"1.0 1.0 1.0 1.0"
      },
      "frequency":2,
      "count":10,
      "speed":0.05,
      "spread":{
         "x":3.00,
         "y":1.00,
         "z":3.00
      },
      "offset_y":0.20,
      "visible_in_first_person":false,
      "visible_while_invisible":false,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/white_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "overlay":{
      "type":"origins:overlay",
      "texture":"minecraft:textures/block/white_stained_glass.png",
      "strength":0.15,
      "red":1.00,
      "green":1.00,
      "blue":1.00,
      "draw_mode":"texture",
      "draw_phase":"below_hud",
      "hide_with_hud":false,
      "visible_in_third_person":true,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/white_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "auto_deactivate_on_erase":{
      "type":"origins:action_over_time",
      "rising_action":{
         "type":"origins:modify_resource",
         "modifier":{
            "operation":"set_total",
            "value":0.00
         },
         "resource":"quirks:limitless/white_resource"
      },
      "interval":1,
      "condition":{
         "type":"origins:and",
         "conditions":[
            {
               "type":"origins:resource",
               "resource":"quirks:limitless/white_resource",
               "comparison":"==",
               "compare_to":1
            },
            {
               "type":"origins:resource",
               "resource":"quirks:universal/quirk_erased",
               "comparison":"==",
               "compare_to":1
            }
         ]
      }
   },
   "reset_on_death":{
      "type":"origins:action_on_callback",
      "entity_action_respawned":{
         "type":"origins:modify_resource",
         "modifier":{
            "operation":"set_total",
            "value":0.00
         },
         "resource":"quirks:limitless/white_resource"
      },
      "execute_chosen_when_orb":false
   }
}