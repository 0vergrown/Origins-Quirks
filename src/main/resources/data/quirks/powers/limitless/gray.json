{
   "badges":[
      {
         "type":"origins:tooltip",
         "sprite":"origins:textures/gui/badge/toggle.png",
         "text":{
            "translate":"badge.quirks.limitless.gray_toggle",
            "with":[
               {
                  "keybind":"key.quirks.quaternary"
               }
            ]
         }
      },
      {
         "type":"origins:tooltip",
         "sprite":"origins:textures/gui/badge/info.png",
         "text":{
            "translate":"badge.quirks.limitless.gray_info"
         }
      }
   ],
   "type":"origins:multiple",
   "resource":{
      "type":"origins:resource",
      "min":0,
      "max":1,
      "hud_render":{
         "should_render":false
      },
      "start_value":0
   },
   "toggle":{
      "type":"origins:active_self",
      "entity_action":{
         "type":"origins:if_else",
         "condition":{
            "type":"origins:resource",
            "resource":"quirks:limitless/gray_resource",
            "comparison":"==",
            "compare_to":0
         },
         "if_action":{
            "type":"origins:and",
            "actions":[
               {
                  "type":"origins:modify_resource",
                  "modifier":{
                     "operation":"set_total",
                     "value":1.00
                  },
                  "resource":"quirks:limitless/gray_resource"
               },
               {
                  "type":"origins:play_sound",
                  "sound":"minecraft:entity.enderman.teleport",
                  "volume":0.80,
                  "pitch":1.50
               },
               {
                  "type":"origins:execute_command",
                  "command":"title @s actionbar {\"translate\":\"actionbar.quirks.limitless.gray_active\",\"color\":\"gray\",\"bold\":true,\"italic\":false,\"underlined\":false,\"strikethrough\":false,\"obfuscated\":false}"
               }
            ]
         },
         "else_action":{
            "type":"origins:and",
            "actions":[
               {
                  "type":"origins:modify_resource",
                  "modifier":{
                     "operation":"set_total",
                     "value":0.00
                  },
                  "resource":"quirks:limitless/gray_resource"
               },
               {
                  "type":"origins:play_sound",
                  "sound":"minecraft:entity.enderman.teleport",
                  "volume":0.60,
                  "pitch":0.80
               }
            ]
         }
      },
      "cooldown":10,
      "hud_render":{
         "should_render":false
      },
      "key":{
         "key":"key.quirks.quaternary",
         "continuous":false
      },
      "condition":{
         "type":"origins:and",
         "conditions":[
            {
               "type":"origins:resource",
               "resource":"quirks:limitless/stamina_spatial_energy",
               "comparison":">=",
               "compare_to":100
            },
            {
               "type":"origins:resource",
               "resource":"quirks:universal/quirk_erased",
               "comparison":"==",
               "compare_to":0
            }
         ]
      }
   },
   "damage_reduction":{
      "type":"origins:modify_damage_taken",
      "modifier":{
         "operation":"multiply_total",
         "value":-0.40
      },
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/gray_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "speed_boost":{
      "type":"origins:conditioned_attribute",
      "modifier":{
         "attribute":"minecraft:generic.movement_speed",
         "operation":"multiply_base",
         "value":0.25,
         "name":"Limitless Distortion Speed"
      },
      "tick_rate":20,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/gray_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "energy_drain":{
      "type":"origins:action_over_time",
      "entity_action":{
         "type":"origins:if_else",
         "condition":{
            "type":"origins:resource",
            "resource":"quirks:limitless/stamina_spatial_energy",
            "comparison":"<=",
            "compare_to":0
         },
         "if_action":{
            "type":"origins:modify_resource",
            "modifier":{
               "operation":"set_total",
               "value":0.00
            },
            "resource":"quirks:limitless/gray_resource"
         },
         "else_action":{
            "type":"origins:modify_resource",
            "modifier":{
               "operation":"add_base_early",
               "value":-8.00
            },
            "resource":"quirks:limitless/stamina_spatial_energy"
         }
      },
      "interval":1,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/gray_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "mental_drain":{
      "type":"origins:action_over_time",
      "entity_action":{
         "type":"origins:modify_resource",
         "modifier":{
            "operation":"add_base_early",
            "value":-1.00
         },
         "resource":"quirks:limitless/stamina_mental_strain"
      },
      "interval":20,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/gray_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "active_particles":{
      "type":"origins:particle",
      "particle":{
         "type":"minecraft:dust",
         "params":"0.7 0.7 0.7 0.6"
      },
      "frequency":2,
      "count":8,
      "speed":0.05,
      "spread":{
         "x":0.80,
         "y":0.50,
         "z":0.80
      },
      "offset_y":1.00,
      "visible_in_first_person":false,
      "visible_while_invisible":false,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/gray_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "enchant_particles":{
      "type":"origins:particle",
      "particle":"minecraft:enchant",
      "frequency":3,
      "count":5,
      "speed":0.10,
      "spread":{
         "x":1.00,
         "y":0.60,
         "z":1.00
      },
      "offset_y":0.50,
      "visible_in_first_person":false,
      "visible_while_invisible":false,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/gray_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "overlay":{
      "type":"origins:overlay",
      "texture":"minecraft:textures/block/frosted_ice_0.png",
      "strength":0.25,
      "red":0.60,
      "green":0.60,
      "blue":0.80,
      "draw_mode":"texture",
      "draw_phase":"below_hud",
      "hide_with_hud":false,
      "visible_in_third_person":true,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:limitless/gray_resource",
         "comparison":"==",
         "compare_to":1
      }
   },
   "auto_deactivate_on_erase":{
      "type":"origins:action_over_time",
      "rising_action":{
         "type":"origins:modify_resource",
         "modifier":{
            "operation":"set_total",
            "value":0.00
         },
         "resource":"quirks:limitless/gray_resource"
      },
      "interval":1,
      "condition":{
         "type":"origins:and",
         "conditions":[
            {
               "type":"origins:resource",
               "resource":"quirks:limitless/gray_resource",
               "comparison":"==",
               "compare_to":1
            },
            {
               "type":"origins:resource",
               "resource":"quirks:universal/quirk_erased",
               "comparison":"==",
               "compare_to":1
            }
         ]
      }
   },
   "reset_on_death":{
      "type":"origins:action_on_callback",
      "entity_action_respawned":{
         "type":"origins:modify_resource",
         "modifier":{
            "operation":"set_total",
            "value":0.00
         },
         "resource":"quirks:limitless/gray_resource"
      },
      "execute_chosen_when_orb":false
   }
}