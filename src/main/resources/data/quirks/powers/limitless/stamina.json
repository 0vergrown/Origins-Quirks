{
   "type":"origins:multiple",
   "spatial_energy":{
      "type":"origins:resource",
      "min":0,
      "max":5000,
      "hud_render":{
         "should_render":true,
         "sprite_location":"origins:textures/gui/community/spiderkolo/resource_bar_01.png",
         "bar_index":1
      },
      "start_value":5000
   },
   "mental_strain":{
      "type":"origins:resource",
      "min":0,
      "max":200,
      "hud_render":{
         "should_render":true,
         "sprite_location":"origins:textures/gui/community/spiderkolo/resource_bar_02.png",
         "bar_index":7
      },
      "start_value":200
   },
   "energy_regen":{
      "type":"origins:action_over_time",
      "entity_action":{
         "type":"origins:modify_resource",
         "modifier":{
            "operation":"add_base_early",
            "value":2.00
         },
         "resource":"quirks:limitless/stamina_spatial_energy"
      },
      "interval":1,
      "condition":{
         "type":"origins:resource",
         "resource":"quirks:universal/quirk_erased",
         "comparison":"==",
         "compare_to":0
      }
   },
   "mental_regen":{
      "type":"origins:action_over_time",
      "entity_action":{
         "type":"origins:modify_resource",
         "modifier":{
            "operation":"add_base_early",
            "value":1.00
         },
         "resource":"quirks:limitless/stamina_mental_strain"
      },
      "interval":4,
      "condition":{
         "type":"origins:and",
         "conditions":[
            {
               "type":"origins:resource",
               "resource":"quirks:limitless/stamina_mental_strain",
               "comparison":"!=",
               "compare_to":200
            },
            {
               "type":"origins:resource",
               "resource":"quirks:universal/quirk_erased",
               "comparison":"==",
               "compare_to":0
            }
         ]
      }
   },
   "mental_overload":{
      "type":"origins:action_over_time",
      "entity_action":{
         "type":"origins:and",
         "actions":[
            {
               "type":"origins:damage",
               "amount":2,
               "damage_type":"minecraft:magic"
            },
            {
               "type":"origins:apply_effect",
               "effect":{
                  "effect":"minecraft:nausea",
                  "duration":60,
                  "amplifier":0,
                  "is_ambient":false,
                  "show_particles":true,
                  "show_icon":true
               }
            }
         ]
      },
      "interval":20,
      "condition":{
         "type":"origins:and",
         "conditions":[
            {
               "type":"origins:resource",
               "resource":"quirks:limitless/stamina_mental_strain",
               "comparison":"==",
               "compare_to":0
            },
            {
               "type":"origins:gamemode",
               "gamemode":"creative",
               "inverted":true
            },
            {
               "type":"origins:gamemode",
               "gamemode":"spectator",
               "inverted":true
            }
         ]
      }
   },
   "strain_warning":{
      "type":"origins:action_over_time",
      "rising_action":{
         "type":"origins:and",
         "actions":[
            {
               "type":"origins:execute_command",
               "command":"title @s actionbar {\"translate\":\"actionbar.quirks.limitless.mental_strain_low\",\"color\":\"red\",\"bold\":true,\"italic\":false,\"underlined\":false,\"strikethrough\":false,\"obfuscated\":false}"
            },
            {
               "type":"origins:play_sound",
               "sound":"minecraft:block.note_block.bass",
               "volume":1.00,
               "pitch":0.50
            }
         ]
      },
      "interval":1,
      "condition":{
         "type":"origins:and",
         "conditions":[
            {
               "type":"origins:resource",
               "resource":"quirks:limitless/stamina_mental_strain",
               "comparison":"<=",
               "compare_to":20
            },
            {
               "type":"origins:resource",
               "resource":"quirks:limitless/stamina_mental_strain",
               "comparison":">",
               "compare_to":0
            }
         ]
      }
   },
   "reset_on_death":{
      "type":"origins:action_on_callback",
      "entity_action_respawned":{
         "type":"origins:and",
         "actions":[
            {
               "type":"origins:modify_resource",
               "modifier":{
                  "operation":"set_total",
                  "value":5000.00
               },
               "resource":"quirks:limitless/stamina_spatial_energy"
            },
            {
               "type":"origins:modify_resource",
               "modifier":{
                  "operation":"set_total",
                  "value":200.00
               },
               "resource":"quirks:limitless/stamina_mental_strain"
            }
         ]
      },
      "execute_chosen_when_orb":false
   }
}